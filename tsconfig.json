{
    "compilerOptions": {
        "target": "ESNext",
        "module": "ESNext",
        "moduleResolution": "Bundler",

        "strict": true,
        "noEmit": true,

        "isolatedModules": true,
        "esModuleInterop": true,

        "skipLibCheck": true,

        "noUncheckedIndexedAccess": true,
        "exactOptionalPropertyTypes": true
    },
    "include": [
        "src"
    ]
}
